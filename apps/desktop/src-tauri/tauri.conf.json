{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wechat-cc",
  "version": "0.5.13",
  "identifier": "dev.wechat-cc.installer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "wechat-cc",
        "width": 1100,
        "height": 860,
        "minWidth": 760,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.claude/channels/wechat/inbox/**",
          "$HOME/.claude/channels/wechat/avatars/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "rpm", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/wechat-cc-cli"
    ],
    "linux": {
      "deb": {
        "postInstallScript": "scripts/postinst.sh"
      },
      "rpm": {
        "postInstallScript": "scripts/postinst.sh"
      }
    }
  }
}
