{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the wechat-cc desktop wizard. Grants the bundled wechat-cc-cli sidecar permission to execute and stream output back to the GUI.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/wechat-cc-cli",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
