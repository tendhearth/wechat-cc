{
  "name": "claude-channel-wechat",
  "version": "0.6.2",
  "description": "WeChat channel plugin for Claude Code — bridge WeChat messages in and out of your Claude Code session via the ilink bot API.",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "wechat",
    "ilink",
    "channel"
  ],
  "homepage": "https://github.com/ggshr9/wechat-cc#readme",
  "bugs": {
    "url": "https://github.com/ggshr9/wechat-cc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggshr9/wechat-cc.git"
  },
  "author": "ggshr9",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "bin": {
    "wechat-cc": "./cli.ts"
  },
  "scripts": {
    "start": "bun install --no-summary && bun src/daemon/main.ts",
    "test": "bun --bun vitest run",
    "test:e2e": "bun --bun vitest run -c vitest.e2e.config.ts",
    "eval:companion": "bun eval/companion/run.ts",
    "typecheck": "tsc --noEmit",
    "depcheck": "depcruise --config .dependency-cruiser.cjs src cli.ts setup.ts docs.ts log-viewer.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.116",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "0.128.0",
    "marked": "^18.0.0",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@cursor/sdk": "^1.0.12"
  },
  "devDependencies": {
    "@openai/codex": "0.128",
    "@types/bun": "^1.3.0",
    "citty": "^0.2.2",
    "dependency-cruiser": "^17.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
