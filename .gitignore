node_modules/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Runtime state — all channel data lives under ~/.claude/channels/wechat/,
# not in the repo. These patterns defend against accidental local copies
# landing inside the source tree.
accounts/
*.log
*.pid
.env
.env.*
access.json
context_tokens.json
user_names.json
inbox/
*@im.wechat/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Tauri / Rust desktop installer build output (gigabytes; never commit)
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/schemas/
apps/desktop/src-tauri/WixTools/
# Sidecar binaries are produced per-platform during CI (`bun build --compile`)
# and bundled into the Tauri output. Never commit — they're 60+ MB and machine-
# specific; CI rebuilds them before each desktop release.
apps/desktop/src-tauri/binaries/

# Playwright MCP snapshots — local debugging artifacts
.playwright-mcp/

# Playwright test artifacts (per-run traces / screenshots / state)
apps/desktop/test-results/
apps/desktop/playwright-report/

# Claude Code local state
.claude/
*.bun-build

# RFC 03 spike runtime artifacts (not source — generated by `bun spike.ts`).
# events.jsonl + matrix.json + scratch/ contain run-specific thread_ids and
# observed events; commit summary.json only when capturing evidence.
docs/spike/phase0-rfc03/02-codex-events/events.jsonl
docs/spike/phase0-rfc03/03-codex-perms/scratch/
docs/spike/phase0-rfc03/03-codex-perms/matrix.json

# Companion eval harness — per-run artifacts (markdown reports + jsonl dumps).
# Trajectory YAMLs + judge config are checked in; outputs are not.
eval/companion/runs/
test-results/

# never track node_modules (dir or stray symlink)
node_modules
